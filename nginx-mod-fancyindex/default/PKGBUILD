# $Id$
# Maintainer: Martchus <martchus@gmx.net>

pkgname=nginx-mod-fancyindex
pkgver=0.6.0
pkgrel=1
_dirname="ngx-fancyindex-${pkgver}"
pkgdesc='Fancy indexes module for the Nginx web server'
arch=('x86_64')
makedepends=('nginx' 'nginx-src')
url='https://github.com/aperezdc/ngx-fancyindex'
license=('CUSTOM')

source=("$pkgname-$pkgver::https://github.com/aperezdc/ngx-fancyindex/archive/v${pkgver}.tar.gz")
sha256sums=('d212fdc1393261612126def3e091c376adeda5646130b4240093f47b550bc5ef')

prepare() {
  cd "$srcdir/$_dirname"
}

build() {
  cp -r /usr/src/nginx .
  cd "$srcdir"/nginx
  ./configure --with-compat --add-dynamic-module="../$_dirname"
  make modules
}

package() {
  _nginxver=$(pacman -Q nginx | sed 's|nginx \([^-]*\).*|\1|')
  depends+=("nginx=$_nginxver")

  install -Dm755 "$srcdir/$_dirname/LICENSE" "$pkgdir/usr/share/licenses/${pkgname}/LICENSE"
  cd "$srcdir"/nginx/objs
  for mod in ngx_*.so; do
    install -Dm755 $mod "$pkgdir"/usr/lib/nginx/modules/$mod
  done
}
