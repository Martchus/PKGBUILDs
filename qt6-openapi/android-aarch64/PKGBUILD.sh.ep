% layout 'android-qt6-module', no_libs => 1;
\
_qtver=6.11.0
pkgver=${_qtver/-/}
pkgrel=1
arch=(any)
url='https://www.qt.io'
license=(GPL-3.0-only
         LGPL-3.0-only
         LicenseRef-Qt-Commercial
         Qt-GPL-exception-1.0)
pkgdesc='OpenAPI Generator for the cpp-qt6-client library (android)'
depends=(<%== qt6deps qw(base) %>)
makedepends=('android-cmake<%== $static_suffix %>' <%== qt6deps qw(shadertools declarative) %> 'qt6-openapi' 'qt6-shadertools' 'qt6-declarative' 'ninja')
