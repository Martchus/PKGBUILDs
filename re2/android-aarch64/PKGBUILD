_pkgname=re2
_android_arch=aarch64
pkgname=android-$_android_arch-$_pkgname
pkgrel=1
epoch=1
pkgver=2025.11.05
pkgdesc="Fast, safe, thread-friendly regular expression engine (Android, $_android_arch)"
arch=('x86_64')
url="https://github.com/google/re2"
license=('BSD-3-Clause')
depends=("android-$_android_arch-abseil-cpp")
#checkdepends=("android-$_android_arch-gtest")
makedepends=('android-cmake' 'git')
options=(!strip !buildflags !libtool staticlibs !emptydirs)
source=("$_pkgname::git+https://github.com/google/re2.git#tag=${pkgver//./-}")
sha256sums=('13cb4ba61567d496fc8ed0bc31369e81bbe9ef34ce8c7dffe5219093a576e385')

build() {
  source android-env ${_android_arch}
    local cmake_options=(
    -B build
    -S $_pkgname
    -W no-dev
    -D CMAKE_FIND_ROOT_PATH="${ANDROID_PREFIX}"
    -D BUILD_SHARED_LIBS=ON
    -D RE2_BUILD_TESTING=OFF
  )
  android-$_android_arch-cmake "${cmake_options[@]}"
  cmake --build build
  local cmake_options=(
    -B build-static
    -S $_pkgname
    -W no-dev
    -D CMAKE_FIND_ROOT_PATH="${ANDROID_PREFIX}"
    -D BUILD_SHARED_LIBS=OFF
    -D RE2_BUILD_TESTING=OFF
  )
  android-$_android_arch-cmake "${cmake_options[@]}"
  cmake --build build-static
}

check() {
  return # needed "benchmark"
  local excluded_tests=""
  local ctest_flags=(
    --test-dir build
    # show the stdout and stderr when the test fails
    --output-on-failure
    # execute tests in parallel
    --parallel $(nproc)
    # exclude problematic tests
    --exclude-regex "$excluded_tests"
  )
  ctest "${ctest_flags[@]}" || true
}

package() {
  source android-env ${_android_arch}
  DESTDIR="$pkgdir" cmake --install build
  DESTDIR="$pkgdir" cmake --install build-static
  install -Dm644 $_pkgname/LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  rm -rf "${pkgdir}/${ANDROID_PREFIX_SHARE}"
  ${ANDROID_STRIP} -g --strip-unneeded "${pkgdir}/${ANDROID_PREFIX_LIB}"/*.so
  ${ANDROID_STRIP} -g "${pkgdir}/${ANDROID_PREFIX_LIB}"/*.a
}
